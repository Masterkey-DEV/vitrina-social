    "title": {
      "type": "string",
      "required": true
    },
    "objective": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "images": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "foundation": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::foundation.foundation",
      "inversedBy": "iniciatives"
    },
    "initiatives_categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::initiatives-category.initiatives-category",
      "mappedBy": "initiatives"
    },
    "users": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user",
      "mappedBy": "initiatives"
    }
